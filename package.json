{
  "name": "dark-art-station",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build && cp -r .next/static .next/standalone/.next/static && cp -r public .next/standalone/public",
    "postinstall": "prisma generate",
    "start": "node .next/standalone/server.js",
    "lint": "eslint",
    "ingest": "ts-node -O '{\"module\":\"CommonJS\"}' scripts/import-collections.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.995.0",
    "@aws-sdk/s3-request-presigner": "^3.995.0",
    "@prisma/client": "^6.19.2",
    "lucide-react": "^0.577.0",
    "next": "^15.5.18",
    "react": "19.1.2",
    "react-dom": "19.1.2",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^4.3.6",
    "@next/third-parties": "^15.5.18"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.4.20",
    "eslint": "^9",
    "eslint-config-next": "^15.5.18",
    "postcss": "^8.4.47",
    "prisma": "^6.19.2",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.17",
    "ts-node": "^10.9.2",
    "typescript": "^5"
  }
}