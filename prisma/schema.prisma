generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum DeviceType {
  IPHONE
  ANDROID
  PC
}

model Collection {
  id              String   @id @default(uuid())
  slug            String   @unique
  title           String
  description     String
  metaDescription String?
  category        String
  thumbnail       String
  thumbnailAlt    String?
  downloadUrl     String?

  price       Float    @default(0)
  isFree      Boolean  @default(false)
  badge       String?
  icon        String   @default("🌙")
  bgClass     String   @default("p-bg-1")
  tag         String   @default("Collection")
  featured    Boolean  @default(false)

  /// Set to true for collections with mature/16+ content.
  isAdult     Boolean  @default(false)

  /// Set to false to hide from all public pages and sitemap without deleting.
  isPublished Boolean  @default(true)

  /// Set to true to serve this collection at the site root (e.g.
  /// hauntedwallpapers.com/melodie-brawl-stars-wallpaper) instead of nested
  /// under /collections/. Its images then also get root-level URLs
  /// (e.g. /melodie-4k) instead of /collections/{slug}/{imageSlug}.
  /// The old /collections/{slug} URL keeps working — it 308-redirects here.
  rootSlug    Boolean  @default(false)

  images      Image[]
  downloads   Download[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Image {
  id              String     @id @default(uuid())
  slug            String     @unique
  title           String
  description     String?
  altText         String?
  metaDescription String?
  r2Key           String
  highResKey      String
  viewCount       Int        @default(0)
  sortOrder       Int        @default(0)

  collection    Collection? @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  collectionId  String?

  deviceType    DeviceType?
  tags          String[]    @default([])

  /// Set to true for individual images with mature/16+ content.
  isAdult       Boolean     @default(false)

  /// Set to true to enable birthday wishes / comments on this image.
  commentsEnabled Boolean   @default(false)

  /// Set to true to show this image on the /avatars Discord profile picture page.
  isAvatar      Boolean     @default(false)

  /// When two avatars are a "matching pair" (e.g. soulmate / bestfriend PFPs),
  /// both Image rows share this same id. Null for ordinary, unpaired avatars.
  matchingGroupId String?

  /// Which half of the pair this image is — shown as a tab/dot label in the
  /// slideshow, e.g. "Him" / "Her", "A" / "B". Null when not part of a pair.
  matchingLabel   String?

  downloads     Download[]
  comments      Comment[]

  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([collectionId])
  @@index([deviceType])
  @@index([isAdult, createdAt])
  @@index([tags])
  @@index([matchingGroupId])
}

model Download {
  id           String      @id @default(uuid())
  collection   Collection? @relation(fields: [collectionId], references: [id])
  collectionId String?
  image        Image?      @relation(fields: [imageId], references: [id])
  imageId      String?
  email        String?
  ipHash       String?
  referer      String?
  createdAt    DateTime    @default(now())
}

// ── Blog Posts ────────────────────────────────────────────────────────────────
model BlogPost {
  id            String   @id @default(uuid())
  slug          String   @unique
  title         String
  label         String   @default("Guide")
  content       String   // HTML content
  featuredImage String?
  published     Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model FeedbackReport {
  id        String   @id @default(uuid())
  page      String
  category  String
  message   String
  email     String?
  ip        String?
  status    String   @default("open")  // "open" | "resolved" | "wont-fix"
  createdAt DateTime @default(now())

  @@index([status])
  @@index([createdAt])
}

// ── Page Content (CMS for editable static page text) ─────────────────────────
model PageContent {
  id        String   @id @default(uuid())
  slug      String   @unique   // e.g. "about", "blog", "faq"
  title     String?
  body      String   @default("")
  metaDesc  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ── Cookie Consent (Safari ITP fallback) ─────────────────────────────────────
model CookieConsent {
  id        String   @id @default(uuid())
  anonId    String   @unique
  value     String             // "accepted" | "declined"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([anonId])
}

// ── Comments / Birthday Wishes ────────────────────────────────────────────────
model Comment {
  id        String   @id @default(uuid())
  imageId   String
  image     Image    @relation(fields: [imageId], references: [id], onDelete: Cascade)
  name      String
  message   String
  status    String   @default("pending")  // "pending" | "approved" | "deleted"
  likes     Int      @default(0)
  ipHash    String?
  createdAt DateTime @default(now())

  @@index([imageId])
  @@index([status])
}

// ── Vanity Redirects ──────────────────────────────────────────────────────────
model VanityRedirect {
  id          String   @id @default(uuid())
  slug        String   @unique
  destination String
  label       String?
  clicks      Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([slug])
}

// ── First-party Analytics (replaces relying on Umami alone) ──────────────────
// Session id is generated client-side (lib/track.ts) and stored in a
// first-party cookie, so it survives ad-blockers that kill third-party
// analytics scripts. No raw IP is ever stored — only a salted one-way hash,
// same pattern already used on the Download model.
model Session {
  id        String    @id // client-generated UUID, not DB-generated
  ipHash    String
  userAgent String?
  device    String?   // "iphone" | "android-mobile" | "tablet" | "desktop"
  country   String?   // from cf-ipcountry header if behind Cloudflare proxy, else null
  firstSeen DateTime  @default(now())
  lastSeen  DateTime  @updatedAt

  pageViews PageView[]
  events    AnalyticsEvent[]

  @@index([lastSeen])
}

model PageView {
  id        String   @id @default(uuid())
  sessionId String
  session   Session  @relation(fields: [sessionId], references: [id])
  path      String
  enteredAt DateTime @default(now())
  duration  Int?     // seconds, filled in via visibilitychange/pagehide beacon

  @@index([sessionId])
  @@index([path])
  @@index([enteredAt])
}

model AnalyticsEvent {
  id        String   @id @default(uuid())
  sessionId String
  session   Session  @relation(fields: [sessionId], references: [id])
  path      String
  type      String   // "download" | "preview_open" | "favorite_save" | "wallpaper_view" | "engaged_15s" | "engaged_60s" | ...
  meta      Json?
  createdAt DateTime @default(now())

  @@index([sessionId])
  @@index([type])
  @@index([createdAt])
}

// ── Live Wallpapers ───────────────────────────────────────────────────────────
model LiveWallpaper {
  id           String   @id @default(uuid())
  slug         String   @unique
  title        String
  description  String?
  r2Key        String             // path in R2 e.g. live-wallpapers/slug.mp4
  thumbnailKey String   @default("")   // poster image shown before video loads
  hasSound     Boolean  @default(false)
  tags         String[] @default([])
  viewCount    Int      @default(0)
  isPublished  Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([isPublished, createdAt])
}

// ── Residents of the Haunted Town ─────────────────────────────────────────────
model Resident {
  id          String   @id @default(uuid())
  slug        String   @unique
  name        String
  tagline     String                   // one-liner trait shown on grid card
  story       String   @default("")   // HTML — full lore narrative
  personality String   @default("")   // HTML — personality breakdown
  portraitKey String   @default("")   // R2 key for 9:16 portrait image
  order       Int      @default(0)    // manual sort order on /residents grid
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isPublished, order])
}
