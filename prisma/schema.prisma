generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum DeviceType {
  IPHONE
  ANDROID
  PC
}

model Collection {
  id          String   @id @default(uuid())
  slug        String   @unique
  title       String
  description String
  category    String
  thumbnail   String   // R2 key: thumbnails/<slug>.webp  (collection cover)
  downloadUrl String?  // R2 key: files/<slug>.zip  (optional bundle ZIP)

  // ── UI / display fields ──────────────────────────────
  price       Float    @default(0)
  isFree      Boolean  @default(false)
  badge       String?
  icon        String   @default("🌙")
  bgClass     String   @default("p-bg-1")
  tag         String   @default("Collection")
  featured    Boolean  @default(false)

  // ── Relations ────────────────────────────────────────
  images      Image[]
  downloads   Download[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Image {
  id            String     @id @default(uuid())
  slug          String     @unique   // e.g. "hecate-moonrise" — unique across all images
  title         String
  description   String?
  r2Key         String     // thumbnails/<collection-slug>/<image-slug>.webp
  highResKey    String     // high-res/<collection-slug>/<image-slug>.png
  viewCount     Int        @default(0)
  sortOrder     Int        @default(0)   // controls display order within collection

  collection    Collection? @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  collectionId  String?

  // ── Standalone fields ────────────────────────────────
  deviceType    DeviceType?         // IPHONE | ANDROID | PC — set only for standalone images
  tags          String[]            @default([])

  downloads     Download[]

  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@index([collectionId])
  @@index([deviceType])
}

// Tracks download events — works for both collection ZIPs and individual images
model Download {
  id           String      @id @default(uuid())
  collection   Collection? @relation(fields: [collectionId], references: [id])
  collectionId String?
  image        Image?      @relation(fields: [imageId], references: [id])
  imageId      String?
  email        String?
  ipHash       String?
  createdAt    DateTime    @default(now())
}