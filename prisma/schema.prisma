generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum DeviceType {
  IPHONE
  ANDROID
  PC
}

model Collection {
  id              String   @id @default(uuid())
  slug            String   @unique
  title           String
  description     String
  metaDescription String?
  category        String
  thumbnail       String
  thumbnailAlt    String?
  downloadUrl     String?

  price       Float    @default(0)
  isFree      Boolean  @default(false)
  badge       String?
  icon        String   @default("🌙")
  bgClass     String   @default("p-bg-1")
  tag         String   @default("Collection")
  featured    Boolean  @default(false)

  /// Set to true for collections with mature/16+ content.
  isAdult     Boolean  @default(false)

  images      Image[]
  downloads   Download[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Image {
  id              String     @id @default(uuid())
  slug            String     @unique
  title           String
  description     String?
  altText         String?
  metaDescription String?
  r2Key           String
  highResKey      String
  viewCount       Int        @default(0)
  sortOrder       Int        @default(0)

  collection    Collection? @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  collectionId  String?

  deviceType    DeviceType?
  tags          String[]    @default([])

  /// Set to true for individual images with mature/16+ content.
  isAdult       Boolean     @default(false)

  /// Set to true to enable birthday wishes / comments on this image.
  commentsEnabled Boolean   @default(false)

  downloads     Download[]
  comments      Comment[]

  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([collectionId])
  @@index([deviceType])
}

model Download {
  id           String      @id @default(uuid())
  collection   Collection? @relation(fields: [collectionId], references: [id])
  collectionId String?
  image        Image?      @relation(fields: [imageId], references: [id])
  imageId      String?
  email        String?
  ipHash       String?
  createdAt    DateTime    @default(now())
}

// ── Blog Posts ────────────────────────────────────────────────────────────────
model BlogPost {
  id            String   @id @default(uuid())
  slug          String   @unique
  title         String
  label         String   @default("Guide")
  content       String   // HTML content
  featuredImage String?
  published     Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model FeedbackReport {
  id        String   @id @default(uuid())
  page      String
  category  String
  message   String
  email     String?
  ip        String?
  status    String   @default("open")  // "open" | "resolved" | "wont-fix"
  createdAt DateTime @default(now())

  @@index([status])
  @@index([createdAt])
}

// ── Page Content (CMS for editable static page text) ─────────────────────────
model PageContent {
  id        String   @id @default(uuid())
  slug      String   @unique   // e.g. "about", "blog", "faq"
  title     String?
  body      String   @default("")
  metaDesc  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ── Cookie Consent (Safari ITP fallback) ─────────────────────────────────────
// Stores anonymous consent decisions server-side so Safari's ITP can't wipe them.
// anonId is generated client-side (crypto.randomUUID) and stored in localStorage.
model CookieConsent {
  id        String   @id @default(uuid())
  anonId    String   @unique   // anonymous client ID — no PII
  value     String             // "accepted" | "declined"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([anonId])
}

// ── Comments / Birthday Wishes ────────────────────────────────────────────────
model Comment {
  id        String   @id @default(uuid())
  imageId   String
  image     Image    @relation(fields: [imageId], references: [id], onDelete: Cascade)
  name      String
  message   String
  status    String   @default("pending")  // "pending" | "approved" | "deleted"
  likes     Int      @default(0)
  ipHash    String?
  createdAt DateTime @default(now())

  @@index([imageId])
  @@index([status])
}
